---
// src/pages/projects/consent-sync-detail.astro

import Layout from '../../layouts/Layout.astro';

const project = {
  title: "Consent synchronisation engine",
  context: "Salesforce Marketing Cloud · data engineering",
  backUrl: "/projects/consent-sync",
};

// Placeholder — swap once the image is saved into the project, e.g.:
// public/images/consent-sync-detail.png
const imageSrc = "/images/consent-sync-detail.png";
const imageAlt = "Consent synchronisation engine illustration";
---

<Layout title={project.title} description={`Visual breakdown of ${project.title}.`}>
    <style>
      :root {
        --accent: #0055ff;
        --accent-bg: #f0f5ff;
        --accent-line: #d6e4ff;
        --line: #e1e4e6;
        --ink: #222;
        --muted: #555;
        --soft: #f7f8fa;
      }
      * { box-sizing: border-box; }
      body {
        font-family: system-ui, sans-serif;
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 20px;
        color: var(--ink);
        line-height: 1.6;
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        color: var(--accent);
        text-decoration: none;
        margin: 0 0 28px;
        font-weight: 500;
        transition: opacity 0.2s;
      }
      .back-link:hover { opacity: 0.7; }
      .context {
        font-size: 0.8rem;
        color: var(--muted);
        letter-spacing: 0.03em;
        margin: 0 0 10px;
      }
      h1 { margin: 0 0 28px; font-size: 2rem; }

      .image-frame {
        border: 1px solid var(--line);
        border-radius: 12px;
        background: var(--soft);
        overflow: hidden;
        margin: 0 0 32px;
      }
      .image-frame img {
        display: block;
        width: 100%;
        height: auto;
      }
      .image-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 260px;
        color: var(--muted);
        font-size: 0.9rem;
        padding: 20px;
        text-align: center;
      }
    </style>

    <a href={project.backUrl} class="back-link">← Back to consent sync</a>

    <p class="context">{project.context}</p>
    <h1>{project.title}</h1>

    <div class="image-frame">
      <img
        src={imageSrc}
        alt={imageAlt}
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
      />
      <div class="image-placeholder" style="display: none;">
        Image will appear here once saved to public/images/consent-sync-detail.png
      </div>
    </div>
</Layout>