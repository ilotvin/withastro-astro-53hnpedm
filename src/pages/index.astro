---
// src/pages/index.astro

// 1. Explicit project configurations (mapping funnels to your exact file slugs)
const explicitProjects = [
  {
    slug: 'sfmc-email-analytics', // Matches sfmc-email-analytics.md
    funnel: ['_Job', '_Sent', '_Open', '_Click', '_Bounce', '_Unsubscribe'],
  },
  {
    slug: 'consent-sync', // Matches consent-sync.astro if applicable
    funnel: ['Landing Page', 'Form Submit', 'API Trigger', 'Double Opt-In Email', 'Confirmation'],
  },
  {
    slug: 'selling-points-analytics-detail', // Matches selling-points-analytics-detail.md
    funnel: ['Source Data', 'SQL Query', 'Analytics DE', 'Selling Points', 'Reporting'],
  }
];

// 2. Auto-discover markdown project detail pages dynamically
const mdFiles = import.meta.glob('./projects/*.md', { eager: true });

// 3. Format dynamic markdown files
const discoveredProjects = Object.entries(mdFiles).map(([filePath, file]: [string, any]) => {
  const slug = filePath.replace('./projects/', '').replace('.md', '');
  return {
    slug,
    url: `/projects/${slug}`,
    title: file.frontmatter?.title || "Untitled Project",
    summary: file.frontmatter?.summary || "No summary provided.",
    tags: file.frontmatter?.tags || [],
    funnel: file.frontmatter?.funnel || []
  };
});

// 4. SMART MERGE: Merge by the file slug to ensure exactly one unique card per project
const finalProjectsMap = new Map();

// First, seed with discovered Markdown files
discoveredProjects.forEach(proj => {
  finalProjectsMap.set(proj.slug, proj);
});

// Next, append or overlay explicit data configurations
explicitProjects.forEach(explicitProj => {
  if (finalProjectsMap.has(explicitProj.slug)) {
    const existing = finalProjectsMap.get(explicitProj.slug);
    finalProjectsMap.set(explicitProj.slug, { ...existing, funnel: explicitProj.funnel });
  } else {
    // Fallback card layout if the markdown file hasn't been created yet
    finalProjectsMap.set(explicitProj.slug, {
      slug: explicitProj.slug,
      url: `/projects/${explicitProj.slug}`,
      title: explicitProj.slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
      summary: "Summary configuration loading from project file...",
      tags: [],
      funnel: explicitProj.funnel
    });
  }
});

const projects = Array.from(finalProjectsMap.values());
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Professional Portfolio</title>
    <style>
        :root { --accent: #0055ff; --line: #e1e4e6; }
        * { box-sizing: border-box; }
        body { font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 40px 20px; color: #222; }
        h1 { margin: 0 0 8px; }
        .intro { color: #555; margin: 0 0 30px; }
        hr { margin: 30px 0; border: 0; border-top: 1px solid #eee; }
        .project-card { border: 1px solid var(--line); padding: 20px; margin-bottom: 20px; border-radius: 8px; transition: border-color 0.2s; text-decoration: none; display: block; }
        .project-card:hover { border-color: var(--accent); }
        .tag-row { display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 12px; }
        .tag { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent); background: #f0f5ff; border: 1px solid #d6e4ff; border-radius: 999px; padding: 4px 12px; }
        .project-link { font-size: 1.5rem; color: var(--accent); font-weight: bold; margin: 0 0 5px 0; }
        .project-summary { color: #555; margin: 0 0 16px; }
        .funnel-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: #999; margin: 0 0 10px; }
        .funnel-strip { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
        .funnel-step { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85rem; font-weight: 600; color: #444; background: #f6f8fa; border: 1px solid #e1e4e6; border-radius: 6px; padding: 5px 10px; white-space: nowrap; }
        .funnel-arrow { color: #bbb; font-size: 0.95rem; }
        .empty-state { color: #999; font-style: italic; }
    </style>
</head>
<body>
    <h1>Welcome to My Platform</h1>
    <p class="intro">Select a project below to see the visual architecture and technical breakdowns.</p>

    <hr />

    <section>
        {projects.length === 0 ? (
            <p class="empty-state">No projects found.</p>
        ) : (
            projects.map((project) => (
                <div key={project.url}>
                    <a href={project.url} class="project-card">
                        {project.tags && project.tags.length > 0 && (
                            <div class="tag-row">
                                {project.tags.map((tag) => (
                                    <span class="tag" data-tag={tag}>{tag}</span>
                                ))}
                            </div>
                        )}
                        <div class="project-link">{project.title}</div>
                        <p class="project-summary">{project.summary}</p>
                        
                        {project.funnel && project.funnel.length > 0 && (
                            <div>
                                <p class="funnel-label">Pipeline Visual Flow</p>
                                <div class="funnel-strip">
                                    {project.funnel.map((step, i) => (
                                        <div style="display: inline-flex; align-items: center; gap: 8px; margin-bottom: 4px;" key={step}>
                                            <span class="funnel-step">{step}</span>
                                            {i < project.funnel.length - 1 && <span class="funnel-arrow">→</span>}
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}
                    </a>
                </div>
            ))
        )}
    </section>
</body>
</html>