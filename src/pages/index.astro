---
const projects = Object.values(
  import.meta.glob('./projects/*.md', { eager: true })
).map((project) => ({
  url: `/projects/${project.file.split('/').pop().replace('.md', '')}`,
  title: project.frontmatter.title,
  summary: project.frontmatter.summary,
}));
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Professional Portfolio</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 40px 20px; color: #222; }
        .project-card { border: 1px solid #e1e4e6; padding: 20px; margin-bottom: 20px; border-radius: 8px; transition: border-color 0.2s; text-decoration: none; display: block; }
        .project-card:hover { border-color: #0055ff; }
        .project-link { font-size: 1.5rem; color: #0055ff; font-weight: bold; margin: 0 0 5px 0; }
        .project-summary { color: #555; margin: 0; }
    </style>
</head>
<body>
    <h1>Welcome to My Platform</h1>
    <p>Select a project below to see the visual architecture and technical breakdowns.</p>

    <hr style="margin: 30px 0; border: 0; border-top: 1px solid #eee;" />

    <section>
        {projects.map((project) => (
            <a href={project.url} class="project-card">
                <div class="project-link">{project.title}</div>
                <p class="project-summary">{project.summary}</p>
            </a>
        ))}
    </section>
</body>
</html>