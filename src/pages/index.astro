---
// Import the new file reading tools from Astro
import { getCollection, defineCollection } from 'astro:content';

// This automatically reads all markdown files inside the current pages directory
const projects = await Astro.glob('./*.md');
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Professional Portfolio</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 40px 20px; color: #222; }
        .project-card { border: 1px solid #e1e4e6; padding: 20px; margin-bottom: 20px; border-radius: 8px; transition: border-color 0.2s; }
        .project-card:hover { border-color: #0055ff; }
        .project-link { font-size: 1.5rem; color: #0055ff; text-decoration: none; font-weight: bold; }
        .project-summary { color: #555; margin-top: 5px; }
    </style>
</head>
<body>
    <h1>Welcome to My Platform</h1>
    <p>Select a project below to see the visual architecture and technical breakdowns.</p>
    
    <hr style="margin: 30px 0; border: 0; border-top: 1px solid #eee;" />

    <section>
        {projects.length === 0 ? (
            <p>No projects found yet. Create a .md file in your pages folder to see it appear here!</p>
        ) : (
            projects.map((project) => (
                <div class="project-card">
                    <a href={project.url} class="project-link">
                        {project.frontmatter?.title || "Untitled Project"}
                    </a>
                    <p class="project-summary">{project.frontmatter?.summary || "No summary provided."}</p>
                </div>
            ))
        )}
    </section>
</body>
</html>