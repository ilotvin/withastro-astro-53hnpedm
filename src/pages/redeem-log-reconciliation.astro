---
// src/pages/redeem-log-reconciliation.astro

import Layout from '../layouts/Layout.astro';

const title = "Redeem Log Date Reconciliation Mechanism";

const slides = [
  { id: "title" },
  { id: "problem" },
  { id: "root-cause" },
  { id: "solution" },
  { id: "query" },
  { id: "analogy" },
  { id: "benefits" },
  { id: "implementation" },
  { id: "summary" },
];
---

<Layout title={title} description="A mechanism for identifying and resolving date discrepancies between DE_Order_Details and NY3_Redeem_Log.">
    <div class="presentation-container">
      <!-- Slide 1: Title -->
      <div class="slide active title-slide" data-slide="0">
        <div class="slide-title">Redeem Log Date Reconciliation</div>
        <div class="slide-subtitle">Synchronizing Order and Redemption Data</div>
        <div class="slide-content">
          <p style="margin-top: 40px;">
            A comprehensive mechanism for identifying and resolving date discrepancies
            between DE_Order_Details and NY3_Redeem_Log
          </p>
          <p style="margin-top: 60px; font-size: 16px;">Data Quality Assurance Initiative</p>
        </div>
      </div>

      <!-- Slide 2: The Problem -->
      <div class="slide" data-slide="1">
        <div class="slide-title">The Problem: Date Discrepancies</div>
        <div class="slide-content">
          <div class="problem-box">
            <strong>Issue:</strong> Inconsistency between redemption dates across two data sources
          </div>

          <p><strong>Two Primary Data Sources:</strong></p>
          <div class="list-item">DE_Order_Details: Backend invoice data (Invoice_Date) - authoritative source</div>
          <div class="list-item">NY3_Redeem_Log: API-based website data (Date_Time) - potentially delayed</div>

          <p style="margin-top: 30px;"><strong>Real Example:</strong></p>
          <div class="highlight">
            Customer 7763266's reward redemption:<br />
            • Orders_Details shows: 2024-05-29<br />
            • Redeem_Log shows: 2024-09-01<br />
            • Discrepancy: 4 months difference
          </div>
        </div>
      </div>

      <!-- Slide 3: Root Cause -->
      <div class="slide" data-slide="2">
        <div class="slide-title">Why This Happens</div>
        <div class="slide-content">
          <p><strong>Data Source Lag:</strong></p>
          <div class="list-item">Orders_Details is updated directly from backend systems with real invoice dates</div>
          <div class="list-item">Redeem_Log arrives via API from the website with processing delays</div>
          <div class="list-item">CRC (boutique) redemptions can arrive up to 3 months late</div>

          <div class="flow-diagram">
            <div class="flow-box">Backend Invoice</div>
            <div class="arrow">→</div>
            <div class="flow-box">Orders_Details<br />(Accurate)</div>
            <div class="arrow">→</div>
            <div class="flow-box">API Delay</div>
            <div class="arrow">→</div>
            <div class="flow-box">Redeem_Log<br />(Delayed)</div>
          </div>

          <p style="margin-top: 30px;"><strong>Result:</strong> Customer loyalty point calculations become unreliable</p>
        </div>
      </div>

      <!-- Slide 4: The Solution -->
      <div class="slide" data-slide="3">
        <div class="slide-title">The Reconciliation Mechanism</div>
        <div class="slide-content">
          <p><strong>Core Principle:</strong> DE_Order_Details is the authoritative source</p>

          <div class="solution-box">
            <strong>Three-Step Process:</strong><br /><br />
            <strong>Step 1: Identify Discrepancies</strong><br />
            Compare dates between both tables using DATEDIFF function<br /><br />
            <strong>Step 2: Cross-Reference</strong><br />
            Join records by Customer ID and Product ID<br /><br />
            <strong>Step 3: Update or Insert</strong><br />
            Sync Redeem_Log dates with Orders_Details dates
          </div>

          <p style="margin-top: 30px;"><strong>Update Logic:</strong></p>
          <div class="list-item">If record exists in both: Update Redeem_Log date to match Orders_Details</div>
          <div class="list-item">If record exists only in Orders_Details: Add it to Redeem_Log</div>
          <div class="list-item">Always use the earlier, more accurate Orders_Details date</div>
        </div>
      </div>

      <!-- Slide 5: The Query -->
      <div class="slide" data-slide="4">
        <div class="slide-title">Detection Query</div>
        <div class="slide-content">
          <p><strong>Identifying Date Discrepancies:</strong></p>
          <div class="code-block">
SELECT TOP 100 PERCENT
  CAST(o.Cust_id AS INT) AS Cust_id,
  r.Gift_id,
  r.Points,
  r.Date_Time,
  o.Invoice_Date,
  DATEDIFF(month, o.Invoice_Date, r.Date_Time) AS Month_Diff
FROM DE_Order_Details o
JOIN NY3_Redeem_Log r
  ON CAST(r.Cust_id AS INT) = CAST(o.Cust_id AS INT)
  AND r.Gift_id = o.Product
WHERE o.Product LIKE 'REWARD%'
  AND DATEDIFF(month, o.Invoice_Date, r.Date_Time) &lt;&gt; 0
ORDER BY o.Cust_id, o.Invoice_Date
          </div>

          <p><strong>What This Query Does:</strong></p>
          <div class="list-item">Finds all REWARD product transactions</div>
          <div class="list-item">Identifies where month difference is not zero</div>
          <div class="list-item">Returns all discrepancies for review and correction</div>
        </div>
      </div>

      <!-- Slide 6: The Analogy -->
      <div class="slide" data-slide="5">
        <div class="slide-title">Understanding the Mechanism</div>
        <div class="slide-content">
          <div class="analogy-container">
            <strong>Analogy: Two Clocks Tracking One Event</strong><br /><br />
            <strong>Orders_Details (Official Clock):</strong><br />
            Accurate, authoritative timepiece showing the true moment of redemption<br /><br />
            <strong>Redeem_Log (Less Precise Clock):</strong><br />
            Updates arrive with delays via API and batch imports<br /><br />
            <strong>Our Mechanism (The Synchronizer):</strong><br />
            Continuously compares both clocks and adjusts the less precise one to match the official time
          </div>

          <p style="margin-top: 30px;">
            This ensures that all downstream customer calculations—loyalty points, balances, and rewards—are based
            on accurate transaction dates.
          </p>
        </div>
      </div>

      <!-- Slide 7: Benefits & Impact -->
      <div class="slide" data-slide="6">
        <div class="slide-title">Benefits & Business Impact</div>
        <div class="slide-content">
          <p><strong>Data Quality Improvements:</strong></p>
          <div class="list-item">Eliminates date-based calculation errors affecting ~17% of customer base</div>
          <div class="list-item">Ensures accurate point balances and loyalty program integrity</div>
          <div class="list-item">Reduces customer complaints from incorrect redemption records</div>

          <p style="margin-top: 30px;"><strong>Operational Benefits:</strong></p>
          <div class="list-item">Automated detection prevents manual reconciliation overhead</div>
          <div class="list-item">Audit trail preserved for compliance and investigation</div>
          <div class="list-item">Enables accurate financial reporting for loyalty program</div>

          <p style="margin-top: 30px;"><strong>Long-term Strategy:</strong></p>
          <div class="list-item">
            Partner with backend team to adjust source data (order entry date instead of invoice date) to prevent
            discrepancies upstream
          </div>
        </div>
      </div>

      <!-- Slide 8: Implementation -->
      <div class="slide" data-slide="7">
        <div class="slide-title">Implementation Approach</div>
        <div class="slide-content">
          <p><strong>Current Status:</strong></p>
          <div class="list-item">Mechanism designed and tested with Marketing Cloud data extensions</div>
          <div class="list-item">Query logic validated against known discrepancies</div>
          <div class="list-item">Cross-functional collaboration: Noam (date logic fixes), Marina (import mechanisms)</div>

          <p style="margin-top: 30px;"><strong>Next Steps:</strong></p>
          <div class="list-item">Deploy automated detection running on defined schedule</div>
          <div class="list-item">Monitor Import_Redeem_Log_CRC for delayed redemptions</div>
          <div class="list-item">Review and resolve identified discrepancies</div>
          <div class="list-item">Coordinate with backend team on upstream data improvements</div>

          <p style="margin-top: 30px;"><strong>Monitoring:</strong></p>
          <div class="list-item">Track resolution rates and discrepancy trends</div>
          <div class="list-item">Validate customer point calculations post-correction</div>
        </div>
      </div>

      <!-- Slide 9: Summary -->
      <div class="slide title-slide" data-slide="8">
        <div class="slide-title">Key Takeaways</div>
        <div class="slide-content" style="text-align: left; font-size: 20px;">
          <p>✓ Date discrepancies between Orders and Redeem Log affect customer trust and loyalty calculations</p>
          <p>✓ Root cause: API delays and system lag between data sources</p>
          <p>✓ Solution: Systematic reconciliation mechanism using Orders_Details as authoritative source</p>
          <p>✓ Impact: Improved data quality for ~400 customers (17% of base)</p>
          <p>✓ Benefit: Accurate loyalty program administration and customer satisfaction</p>
        </div>
      </div>

      <!-- Controls -->
      <div class="controls">
        <button id="prev-btn">← Previous</button>
        <span class="slide-counter"><span id="current-slide">1</span> / {slides.length}</span>
        <button id="next-btn">Next →</button>
      </div>
    </div>

    <script>
      let currentSlide = 0;
      const slideEls = document.querySelectorAll<HTMLElement>(".slide");
      const totalSlides = slideEls.length;
      const counterEl = document.getElementById("current-slide");

      function showSlide(n: number) {
        slideEls[currentSlide].classList.remove("active");
        currentSlide = (n + totalSlides) % totalSlides;
        slideEls[currentSlide].classList.add("active");
        if (counterEl) counterEl.textContent = String(currentSlide + 1);
      }

      function nextSlide() {
        showSlide(currentSlide + 1);
      }

      function previousSlide() {
        showSlide(currentSlide - 1);
      }

      document.getElementById("next-btn")?.addEventListener("click", nextSlide);
      document.getElementById("prev-btn")?.addEventListener("click", previousSlide);

      document.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight") nextSlide();
        if (e.key === "ArrowLeft") previousSlide();
      });
    </script>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
      }

      .presentation-container {
        width: 100%;
        max-width: 1000px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        overflow: hidden;
      }

      .slide {
        display: none;
        padding: 60px;
        min-height: 600px;
        animation: fadeIn 0.5s ease-in;
      }

      .slide.active {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      .slide-title {
        font-size: 48px;
        font-weight: bold;
        color: #667eea;
        margin-bottom: 30px;
        border-bottom: 4px solid #667eea;
        padding-bottom: 20px;
      }

      .slide-subtitle {
        font-size: 24px;
        color: #764ba2;
        margin-bottom: 20px;
      }

      .slide-content {
        font-size: 18px;
        line-height: 1.8;
        color: #333;
      }

      .slide-content p {
        margin-bottom: 20px;
      }

      .highlight {
        background-color: #fff3cd;
        padding: 20px;
        border-left: 4px solid #ffc107;
        margin: 20px 0;
        border-radius: 4px;
      }

      .problem-box {
        background-color: #f8d7da;
        border-left: 4px solid #dc3545;
        padding: 20px;
        margin: 20px 0;
        border-radius: 4px;
      }

      .solution-box {
        background-color: #d4edda;
        border-left: 4px solid #28a745;
        padding: 20px;
        margin: 20px 0;
        border-radius: 4px;
      }

      .code-block {
        background-color: #f5f5f5;
        border: 1px solid #ddd;
        padding: 15px;
        margin: 20px 0;
        font-family: "Courier New", monospace;
        font-size: 14px;
        overflow-x: auto;
        border-radius: 4px;
        white-space: pre-wrap;
      }

      .list-item {
        margin: 15px 0;
        padding-left: 30px;
        position: relative;
      }

      .list-item:before {
        content: "→";
        position: absolute;
        left: 0;
        color: #667eea;
        font-weight: bold;
      }

      .controls {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      button {
        background-color: white;
        color: #667eea;
        border: none;
        padding: 12px 24px;
        font-size: 16px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s;
      }

      button:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
      }

      .slide-counter {
        color: white;
        font-weight: bold;
        font-size: 18px;
      }

      .analogy-container {
        background: linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%);
        padding: 25px;
        border-radius: 8px;
        margin: 20px 0;
        border-left: 4px solid #00838f;
      }

      .flow-diagram {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin: 30px 0;
        flex-wrap: wrap;
        gap: 15px;
      }

      .flow-box {
        background: #e3f2fd;
        padding: 15px 20px;
        border-radius: 6px;
        text-align: center;
        flex: 1;
        min-width: 150px;
        border: 2px solid #2196f3;
      }

      .arrow {
        font-size: 24px;
        color: #667eea;
        font-weight: bold;
      }

      .title-slide {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        text-align: center;
      }

      .title-slide .slide-title {
        color: white;
        border-bottom-color: white;
        font-size: 56px;
      }

      .title-slide .slide-subtitle {
        color: #e0e0e0;
        font-size: 28px;
      }

      .title-slide .slide-content {
        color: #f0f0f0;
        font-size: 20px;
      }
    </style>
</Layout>